{
  "name": "simple-chatbot",
  "version": "1.0.0",
  "description": "Simple chatbot desktop app with Mistral integration",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:web": "node server.js",
    "dev": "nodemon server.js",
    "app": "electron .",
    "bubble": "electron . --mode=bubble",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "@mistralai/mistralai": "^0.4.0",
    "axios": "^1.13.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "kokoro-js": "^1.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^35.0.3",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.simplechatbot.desktop",
    "productName": "SimpleChatbot",
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "agent_resources/**/*",
      "project_context/**/*",
      "modes.conf",
      ".env",
      "kokoro-v1.0.onnx",
      "voices.bin",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
